# =============================================================================
# params.env — Master default substitution values for {{PLACEHOLDER}} tokens
# =============================================================================
# All config params.env files inherit from these defaults unless overridden.
# setup.sh reads params.env from the config folder (-c flag) and applies
# every KEY=VALUE as a sed substitution: {{KEY}} → VALUE in all .nml files.
#
# Override from CLI at setup time (highest priority):
#   ./scripts/setup.sh -c configs/with_sic -P storm_eunice_2022 -X BETAMAX=1.50
#
# Available placeholders:
#   Dates        : {{START_DATE}} {{END_DATE}} {{YEAR}} {{MONTH}}
#                  {{START_DATE}} = model start after spinup offset is applied
#                  {{ANALYSIS_START}} = original calibration period start (no offset)
#                  (set automatically by -P; override with -X)
#   Spin-up      : {{SPINUP_DAYS}}  (default: 1 — offset applied to {{START_DATE}})
#   Physics      : {{BETAMAX}} {{PRO2_DTIME}} {{PRO3_WDTHCG}} {{PRO3_WDTHTH}}
#                  {{MISC_WCOR1}} {{MISC_WCOR2}}
#   Output       : {{OUTPUT_FIELDS}} {{OUTPUT_STRIDE}} {{OUTPUT_PREFIX}}
#   Timesteps    : {{DTMAX}} {{DTXY}} {{DTKTH}} {{DTMIN}}
#   Wind forcing : {{WIND_FILENAME}} {{WIND_LON_DIM}} {{WIND_LAT_DIM}}
#                  {{WIND_VAR_X}} {{WIND_VAR_Y}}
#   Ice forcing  : {{ICE_FILENAME}} {{ICE_LON_DIM}} {{ICE_LAT_DIM}}
#                  {{SIC_VAR}} {{THICK_VAR}}
# =============================================================================

# --- Physics (namelist.nml) ---
BETAMAX=1.43
PRO2_DTIME=2500.
PRO3_WDTHCG=1.50
PRO3_WDTHTH=1.50
MISC_WCOR1=99
MISC_WCOR2=0.0

# --- Output (ww3_shel.nml + ww3_ounf.nml) ---
# Minimal by default; override per-config or via -X for calibration runs
OUTPUT_FIELDS=HS
OUTPUT_STRIDE=3600
OUTPUT_PREFIX=Wave_CARRA2

# --- Timesteps (ww3_grid.nml) ---
# CFL-limited values for the CARRA2 grid (Pan-Arctic ~4M pts, ~14km res)
DTMAX=270.
DTXY=90.
DTKTH=135.
DTMIN=10.

# --- Wind forcing variable names (ww3_prnc_wind.nml FILE_NML) ---
# Matches CARRA2 NetCDF field names; change per dataset if needed
WIND_FILENAME=wind.nc          # relative path — symlink created by setup.sh
WIND_LON_DIM=x                 # longitude dimension name in NetCDF file
WIND_LAT_DIM=y                 # latitude dimension name in NetCDF file
WIND_VAR_X=x_wind_10m          # x-component variable name
WIND_VAR_Y=y_wind_10m          # y-component variable name

# --- Ice forcing variable names (ww3_prnc_ice.nml.sic / .thick FILE_NML) ---
# Matches CARRA2 NetCDF field names; change per dataset if needed
ICE_FILENAME=ice.nc            # relative path — symlink created by setup.sh
ICE_LON_DIM=x                  # longitude dimension name in NetCDF file
ICE_LAT_DIM=y                  # latitude dimension name in NetCDF file
SIC_VAR=ga_ci_1                # sea-ice concentration variable name
THICK_VAR=ga_sithick_160       # sea-ice thickness variable name

# --- Spin-up (days) ---
# Applied by setup.sh: model start = START_DATE - SPINUP_DAYS
# Original period start is kept as ANALYSIS_START (for output verification).
# Set at period level via manage_periods.sh add --spinup N (default: 1)
# or override per experiment: -X SPINUP_DAYS=2
SPINUP_DAYS=1
