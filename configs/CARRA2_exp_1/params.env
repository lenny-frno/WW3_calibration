# params.env — CARRA2_exp_1 (baseline: wind-forced, no ice)
# Inherits template defaults; wind-only run.

# Physics
BETAMAX=1.43
PRO2_DTIME=2500.
PRO3_WDTHCG=1.50
PRO3_WDTHTH=1.50
MISC_WCOR1=99
MISC_WCOR2=0.0

# Output
OUTPUT_FIELDS=HS
OUTPUT_STRIDE=3600
OUTPUT_PREFIX=Wave_wind_CARRA2

# Timesteps
DTMAX=270.
DTXY=90.
DTKTH=135.
DTMIN=10.
